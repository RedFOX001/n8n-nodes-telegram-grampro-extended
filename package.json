{
	"name": "n8n-nodes-telegram-grampro-extended",
	"version": "1.0.1",
	"description": "Telegram GramPro Extended — enhanced fork of n8n-nodes-telegram-grampro with extended post statistics in getHistory and planned discussion analytics.",
	"license": "MIT",
	"keywords": [
		"n8n",
		"n8n-nodes",
		"n8n-community-node-package",
		"n8n-community-node",
		"telegram",
		"telegram-api",
		"telegram-mtproto",
		"telegram-user",
		"telegram-grampro",
		"telegram-grampro-extended",
		"telegram-js",
		"GramPro",
		"gramjs",
		"workflow automation",
		"userbot",
		"selfbot",
		"client API",
		"marketing automation",
		"message monitoring",
		"auto-responder",
		"scraper"
	],
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"format": "prettier credentials nodes/TelegramGramPro nodes/TelegramGramProTrigger --write",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"n8n-scan": "npx @n8n/scan-community-package n8n-nodes-telegram-grampro-extended",
		"test": "n8n-node lint && n8n-node build",
		"test:unit": "vitest run",
		"test:watch": "vitest",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"author": {
		"name": "RedFOX001",
		"email": "redfox001@users.noreply.github.com"
	},
	"upstream": "https://github.com/sadiakant/n8n-nodes-telegram-grampro",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/RedFOX001/n8n-nodes-telegram-grampro-extended.git"
	},
	"homepage": "https://github.com/RedFOX001/n8n-nodes-telegram-grampro-extended#readme",
	"bugs": {
		"url": "https://github.com/RedFOX001/n8n-nodes-telegram-grampro-extended/issues"
	},
	"dependencies": {
		"teleproto": "^1.224.1"
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.0.1",
		"typescript": "5.9.3",
		"vitest": "^3.1.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"nodes": [
			"dist/nodes/TelegramGramPro/TelegramGramPro.node.js",
			"dist/nodes/TelegramGramProTrigger/TelegramGramProTrigger.node.js"
		],
		"credentials": [
			"dist/credentials/TelegramGramProApi.credentials.js"
		]
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18.17.0"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public",
		"provenance": true
	}
}
